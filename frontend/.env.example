# Frontend env vars (read at build time by Vite — must be set BEFORE `vite build`)

# URL of the TE-main backend that handles trial provisioning + the actual app
# at /app/<token>. The "Commencer ma démo gratuite" button on /demo POSTs to
# `${VITE_TRIAL_API_BASE}/api/auth/start-anonymous-trial` and then redirects
# the visitor to the returned `access_url`.
#
# Dev:  http://localhost:8000  (TE-main backend running locally)
# Prod: https://app.synthese.fr
#
# If unset, the code falls back to http://localhost:8000 — which silently
# breaks the trial flow in production with "Load failed".
VITE_TRIAL_API_BASE=https://app.synthese.fr
